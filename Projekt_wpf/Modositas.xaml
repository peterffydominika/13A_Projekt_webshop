<Window x:Class="Projekt_wpf.Modositas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_wpf"
        mc:Ignorable="d"
        Title="Módosítás" Height="600"
        Width="450"
        FontSize="18"
        Background="LightSkyBlue">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="0, 20,0, 0">
            <Label Content="ID (nem módosítható):" Grid.Row="0"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxId" IsReadOnly="True" Margin="10"/>
            <Label Content="Alkategória id:" Grid.Row="0"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxAlkategoriaId" Margin="10"/>
            <Label Content="Név:"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxNev" Margin="10"/>
            <Label Content="Ár:"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxAr" Margin="10"/>
            <Label Content="Akciós ár:"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxAkciosAr" Margin="10"/>
            <Label Content="Készlet:"/>
            <TextBox HorizontalAlignment="Stretch" x:Name="tbxKeszlet" Margin="10"/>
            <Button x:Name="btnOk" Content="OK" Width="150" Click="btnOk_Click" Margin="20">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
