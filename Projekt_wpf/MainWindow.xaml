<Window x:Class="Projekt_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_wpf"
        mc:Ignorable="d"
        Title="Termékek" Height="500" Width="850"
        Background="LightSkyBlue">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="_Fájl">
                <MenuItem x:Name="miSaveAs" Header="Mentés" Click="btnMent_Click"/>
                <MenuItem x:Name="miExit" Header="Kilépés" Click="btnKilep_Click" InputGestureText="Esc"/>
            </MenuItem>
            <MenuItem Header="Súgó">
                <MenuItem x:Name="miAbout" Header="Névjegy" Click="btnNevjegy_Click" />
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <DataGrid x:Name="dtgAdatok" Margin="20" ColumnWidth="Auto" SelectionChanged="dtgAdatok_SelectionChanged">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="LightBlue"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="DarkBlue"/>
                        <Setter Property="BorderThickness" Value="0 0 1 1"/>
                    </Style>
                </DataGrid.Resources>
            </DataGrid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="20">
                    <Button x:Name="btnFelvisz" Content="Felvitel" HorizontalAlignment="Center" Margin="0 20" Click="btnFelvisz_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnModosit" Content="Módosítás" HorizontalAlignment="Center" Margin="0 20" Click="btnModosit_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnTorol" Content="Törlés" HorizontalAlignment="Center" Margin="0 20" Click="btnTorol_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnMent" Content="Mentés" Margin="20" HorizontalAlignment="Left" Click="btnMent_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8" />
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnBetolt" Content="Betöltés" HorizontalAlignment="Right" Margin="20" Click="btnBetolt_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8" />
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
                <Button x:Name="btnKilep" Grid.Row="1" Content="Kilép" HorizontalAlignment="Center" VerticalAlignment="Top" Click="btnKilep_Click" IsCancel="True">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
